# Vercel / Resend（問い合わせフォームで必須）
# Vercelの「Project Settings > Environment Variables」へ同じ変数名を登録。
# 実際のAPIキーやトークンはリポジトリへ保存しない。
RESEND_API_KEY=

# 問い合わせ通知の受信先
CONTACT_TO_EMAIL=ai.daigaku.jp@gmail.com

# Resendの送信元には、Resendで認証済みの独自ドメインが必要。
# 下記は例。認証済みドメインのアドレスへ置換。
CONTACT_FROM_EMAIL="株式会社HAYASHI CREATIVE <contact@your-verified-domain.example>"

# フォーム送信の予備経路（任意）
FALLBACK_AUTOREPLY_URL=

# SMTPの予備設定（任意）。SMTP_HOST、SMTP_USER、SMTP_PASSがすべて埋まると
# ResendよりSMTPが優先される。Resend利用時は空欄のまま。
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=

# アクセス計測API（任意）
ANALYTICS_SUMMARY_TOKEN=
ANALYTICS_WEBHOOK_URL=

# ローカル開発サーバー（任意）
PORT=8030
