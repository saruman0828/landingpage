# Optional: replace the temporary calendar link in src/components/contact-form.tsx
# with your actual booking page before publishing.
NEXT_PUBLIC_CALENDAR_URL=https://example.com/calendar
NEXT_PUBLIC_SITE_URL=https://example.com

# Form notification email.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=owner@example.com
CONTACT_FROM_EMAIL=株式会社HAYASHI CREATIVE <contact@example.com>

# Optional SMTP fallback. If these are set, SMTP is used before Resend.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=contact@example.com
SMTP_PASS=xxxxxxxxxxxxxxxx
SMTP_FROM_EMAIL=株式会社HAYASHI CREATIVE <contact@example.com>

# Optional fallback auto reply when Resend/SMTP cannot send to the applicant.
FALLBACK_AUTOREPLY_URL=https://formsubmit.co/ajax/0b239698323990ed50d174f1b83077b0

# Optional webhook backup.
DIAGNOSIS_NOTIFY_WEBHOOK=
